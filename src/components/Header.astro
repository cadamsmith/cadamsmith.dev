---
import { siteResources } from '../config/siteResources';
import NavBrand from '../lib/components/NavBrand.svelte';
---

<link rel="preload" as="image" href="/images/profile.png" />
<link rel="preload" as="image" href="/images/profile_alt.png" />

<header>
	<NavBrand client:load />

	<div class="header-right">
		<nav>
			<ul class="nav-group">
				<li>
					<a
						class="icon-link"
						href={siteResources.githubUrl}
						target="_blank"
						aria-label="GitHub"
					>
						<iconify-icon class="iconify-icon" icon="skill-icons:github-dark"
						></iconify-icon>
					</a>
				</li>
				<li>
					<a
						class="icon-link"
						href={siteResources.linkedInUrl}
						target="_blank"
						aria-label="LinkedIn"
					>
						<iconify-icon class="iconify-icon" icon="mdi:linkedin"></iconify-icon>
					</a>
				</li>
			</ul>
			<ul class="nav-group">
				<li>
					<a class="icon-link resume-link" href={siteResources.resumeUrl} target="_blank">
						<iconify-icon class="iconify-icon" icon="mdi:file-pdf-box"></iconify-icon>
						<span>Resume</span>
					</a>
				</li>
				<li>
					<a
						class="icon-link email-link"
						href={`mailto:${siteResources.emailAddress}`}
						aria-label="Contact"
					>
						<iconify-icon class="iconify-icon" icon="mdi:email"></iconify-icon>
					</a>
				</li>
			</ul>
		</nav>
	</div>
</header>

<style>
	header {
		padding: 0.75rem 1rem;
		background-color: var(--color-a);
		color: var(--color-l);
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
		overflow-x: hidden;
		border-bottom: 1px solid var(--color-border);
	}

	.header-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	ul {
		margin: 0;
		padding: 0;
		list-style-type: none;
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	a:not(.icon-link) {
		text-decoration: none;
		color: inherit;
		padding: 0.5em;
		color: var(--color-l);
		font-weight: bold;
		box-sizing: border-box;
	}

	a:not(.icon-link):hover {
		text-decoration: underline;
		color: var(--color-h);
	}

	@media (max-width: 700px) {
		/* The avatar floats centered over the top edge of the button bar, with the
		   four buttons split into a left and right pair flanking it. A 1fr/1fr grid
		   keeps the center gap dead-centered regardless of each pair's width, so the
		   avatar never sits crooked over the wider (Resume) side. */
		header {
			position: relative;
			flex-direction: column;
			align-items: stretch;
			gap: 0;
			background-color: var(--color-b);
			padding: 0;
		}

		.header-right {
			width: 100%;
			background-color: var(--color-a);
			padding: 0.75rem 1rem;
			/* room for the avatar's upper half to sit in the top strip */
			margin-top: 1.5rem;
		}

		/* Icon-only on mobile so all four actions are equal-width — two symmetric
		   pairs that flank the avatar. The gap between them holds the avatar and,
		   because the pairs match, stays centered under it. */
		.resume-link span {
			display: none;
		}

		nav {
			justify-content: space-between;
			width: 100%;
		}
	}
</style>
