---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.scss';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22 x=%22-100%22 transform=%22scale(-1, 1)%22>🦖</text></svg>"
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ClientRouter />
		<title>{title}</title>
		<script is:inline>
			const t = localStorage.getItem('theme');
			if (t) document.documentElement.setAttribute('data-theme', t);
		</script>

		<!--
		You actually looked at the source code for this page, huh?
		Maybe you're a recruiter or something?
		Hire me for your team :)
		You can contact me at cadamsmith.dev@gmail.com
		🦖🦖🦖
		-->
	</head>
	<body>
		<Header />

		<main>
			<slot />
			<div class="content-spacer"></div>
		</main>

		<Footer />

		<script>
			import 'iconify-icon';
		</script>
	</body>
</html>

<style>
	main {
		flex-grow: 1;
	}
</style>
