---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteResources } from '../config/siteResources';
import SkillsWidget from '../lib/components/SkillsWidget.svelte';
import TerminalWidget from '../lib/components/TerminalWidget.svelte';
import Timeline from '../lib/components/Timeline.svelte';
import MusicPlayer from '../lib/components/MusicPlayer.svelte';
import LocationMap from '../lib/components/LocationMap.svelte';
import type { Skill } from '../lib/types/Skill';
import type { TimelineItem } from '../lib/types/TimelineItem';

const now = new Date();

const skillEntries = await getCollection('skills');
const skills: Skill[] = skillEntries
	.map((entry) => ({
		name: entry.data.name,
		group: entry.data.group,
		order: entry.data.order,
		url: entry.data.url,
		imageUrl: entry.data.imageFileName
			? `/images/skills/${entry.data.imageFileName}`
			: '/images/generic_skill.svg'
	}))
	.sort((a, b) => a.order - b.order);

const timelineEntries = await getCollection('timeline');
const timeline: TimelineItem[] = timelineEntries
	.map((entry) => ({
		title: entry.data.title,
		company: entry.data.company,
		group: entry.data.group,
		dateRanges: entry.data.dateRanges,
		order: entry.data.order,
		url: entry.data.url,
		location: entry.data.location,
		coordinates: entry.data.coordinates
	}))
	.sort((a, b) => b.order - a.order);
const latestWorkLocation = timeline.find((item) => item.group === 'Work')?.location ?? '';

const workItems = timeline.filter((item) => item.group === 'Work');
const totalWorkMonths = workItems
	.flatMap((item) => item.dateRanges)
	.reduce((sum, { startDate, endDate }) => {
		const start = new Date(startDate);
		const end = endDate === 'PRESENT' ? now : new Date(endDate);
		const months =
			(end.getFullYear() - start.getFullYear()) * 12 +
			(end.getMonth() - start.getMonth());
		return sum + months;
	}, 0);
const yearsOfWorkExperience = Math.floor(totalWorkMonths / 6) / 2;

const songEntries = await getCollection('songs', ({ data }) => data.enabled);
const songUrls: string[] = songEntries.map((entry) => entry.data.youtubeEmbedUrl);

const heroBlurb = await getEntry('blurbs', 'hero');
const { Content: HeroContent } = await heroBlurb!.render();

const contactBlurb = await getEntry('blurbs', 'contact');
const { Content: ContactContent } = await contactBlurb!.render();

const heroTagEntries = await getCollection('heroTags');
const heroTags = heroTagEntries.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Adam Smith">
	<section class="hero bg-color full-width">
		<h1>Adam Smith</h1>

		<div class="hero-info-tag-list">
			{
				heroTags.map((tag) => (
					<span class="hero-info-tag">
						<iconify-icon class="iconify-icon" icon={tag.data.icon} />
						<span class="hero-info-tag-text">
							{tag.data.label
								.replace('{years}', String(yearsOfWorkExperience))
								.replace('{location}', latestWorkLocation)}
						</span>
					</span>
				))
			}
		</div>

		<div class="hero-split">
			<div class="hero-content">
				<HeroContent />
			</div>

			<div class="terminal-wrapper">
				<TerminalWidget client:visible />
			</div>
		</div>
	</section>

	<section>
		<h2>Technologies</h2>

		<SkillsWidget skills={skills} client:visible />
	</section>
	<section class="bg-color">
		<h2>My Journey</h2>

		<div class="journey-split">
			<div class="map-wrapper">
				<LocationMap initialCoordinates={timeline[0].coordinates} client:only="svelte" />
			</div>
			<div class="journey-content">
				<Timeline timeline={timeline} client:visible />
			</div>
		</div>
	</section>
	<section>
		<div class="contact-split">
			<div class="left">
				<h2>Contact Me</h2>

				<ContactContent />

				<div class="contact-links">
					<a href={`mailto:${siteResources.emailAddress}`}>
						<svg
							class="iconify-icon"
							xmlns="http://www.w3.org/2000/svg"
							width="1em"
							height="1em"
							viewBox="0 0 24 24"
							><path
								fill="currentColor"
								d="m20 8l-8 5l-8-5V6l8 5l8-5m0-2H4c-1.11 0-2 .89-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2"
							></path></svg
						>
						Email
					</a>
					<a href={siteResources.resumeUrl} target="_blank">
						<svg
							class="iconify-icon"
							xmlns="http://www.w3.org/2000/svg"
							width="1em"
							height="1em"
							viewBox="0 0 24 24"
							><path
								fill="currentColor"
								d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2m-9.5 8.5c0 .8-.7 1.5-1.5 1.5H7v2H5.5V9H8c.8 0 1.5.7 1.5 1.5zm5 2c0 .8-.7 1.5-1.5 1.5h-2.5V9H13c.8 0 1.5.7 1.5 1.5zm4-3H17v1h1.5V13H17v2h-1.5V9h3zm-6.5 0h1v3h-1zm-5 0h1v1H7z"
							></path></svg
						>
						Resume
					</a>
					<a href={siteResources.linkedInUrl} target="_blank">
						<svg
							class="iconify-icon"
							xmlns="http://www.w3.org/2000/svg"
							width="1em"
							height="1em"
							viewBox="0 0 24 24"
							><path
								fill="currentColor"
								d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"
							></path></svg
						>
						LinkedIn
					</a>
					<a href={siteResources.githubUrl} target="_blank">
						<svg
							class="iconify-icon"
							xmlns="http://www.w3.org/2000/svg"
							width="1em"
							height="1em"
							viewBox="0 0 24 24"
							><path
								fill="currentColor"
								d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"
							></path></svg
						>
						GitHub
					</a>
				</div>
			</div>
			<div class="right">
				<MusicPlayer youTubeUrls={songUrls} client:only="svelte" />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.hero h1 {
		font-size: 3.8em;
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1;
		margin-bottom: 0.6rem;
		position: relative;
		display: inline-block;
	}

	.hero h1::after {
		content: '';
		display: block;
		width: 2.5rem;
		height: 3px;
		background-color: var(--color-c);
		margin-top: 0.4rem;
		border-radius: 2px;
	}

	.hero-split {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		grid-template-rows: 1fr;
		column-gap: 2em;
	}

	.terminal-wrapper {
		display: flex;
		flex-direction: column;
		height: auto;
	}

	@media (max-width: 800px) {
		.hero-split {
			grid-template-columns: 1fr;
		}

		.terminal-wrapper {
			display: none;
		}

		.map-wrapper {
			display: none;
		}

		.contact-split {
			flex-direction: column;
		}
	}

	.hero-info-tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-bottom: 0.25rem;
	}

	.hero-info-tag {
		background-color: rgba(212, 134, 10, 0.12);
		color: var(--color-c);
		border: 1px solid rgba(212, 134, 10, 0.3);
		padding: 0.2em 0.55em;
		border-radius: 0.25em;
		font-size: 0.88em;
		font-weight: 500;

		display: flex;
		align-items: center;
		gap: 0.3em;
		vertical-align: middle;
	}

	.journey-split {
		display: flex;
		gap: 2em;
	}

	.map-wrapper {
		width: 18rem;
		height: 15rem;
		flex-shrink: 0;
	}

	.journey-content {
		flex-grow: 1;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-bottom: 1rem;
	}

	.contact-links > a {
		background-color: var(--color-c);
		color: #0c0b09;
		padding: 0.3em 0.7em;
		border-radius: 0.25em;
		font-weight: 700;
		font-size: 0.9em;

		display: flex;
		align-items: center;
		gap: 0.3em;
		vertical-align: middle;
		text-decoration: none;
		transition: background-color 0.12s ease;
	}

	.contact-links > a:hover {
		background-color: var(--color-h);
		color: #0c0b09;
		text-decoration: none;
	}

	.contact-split {
		display: flex;
		gap: 2em;
		justify-content: space-between;
	}

	.contact-split .right {
		margin-top: 1rem;
		min-width: 350px;
	}
</style>
