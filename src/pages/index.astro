---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteResources } from '../config/siteResources';
import SkillsWidget from '../lib/components/SkillsWidget.svelte';
import TerminalWidget from '../lib/components/TerminalWidget.svelte';
import Timeline from '../lib/components/Timeline.svelte';
import MusicPlayer from '../lib/components/MusicPlayer.svelte';
import LocationMap from '../lib/components/LocationMap.svelte';
import ProjectsWidget from '../lib/components/ProjectsWidget.svelte';
import type { Skill } from '../lib/types/Skill';
import type { TimelineItem } from '../lib/types/TimelineItem';
import type { Project } from '../lib/types/Project';

const now = new Date();

const skillEntries = await getCollection('skills');
const skills: Skill[] = skillEntries
	.map((entry) => ({
		name: entry.data.name,
		group: entry.data.group,
		order: entry.data.order,
		url: entry.data.url,
		icon: entry.data.icon
	}))
	.sort((a, b) => a.order - b.order);

const timelineEntries = await getCollection('timeline');
const timeline: TimelineItem[] = timelineEntries
	.map((entry) => ({
		title: entry.data.title,
		company: entry.data.company,
		group: entry.data.group,
		dateRanges: entry.data.dateRanges,
		order: entry.data.order,
		url: entry.data.url,
		location: entry.data.location,
		coordinates: entry.data.coordinates
	}))
	.sort((a, b) => b.order - a.order);
const latestWorkLocation = timeline.find((item) => item.group === 'Work')?.location ?? '';

const workItems = timeline.filter((item) => item.group === 'Work');
const totalWorkMonths = workItems
	.flatMap((item) => item.dateRanges)
	.reduce((sum, { startDate, endDate }) => {
		const start = new Date(startDate);
		const end = endDate === 'PRESENT' ? now : new Date(endDate);
		const months =
			(end.getFullYear() - start.getFullYear()) * 12 +
			(end.getMonth() - start.getMonth());
		return sum + months;
	}, 0);
const yearsOfWorkExperience = Math.floor(totalWorkMonths / 6) / 2;

const msPerDay = 86_400_000;
const totalWorkDays = workItems
	.flatMap((item) => item.dateRanges)
	.reduce((sum, { startDate, endDate }) => {
		const start = new Date(startDate);
		const end = endDate === 'PRESENT' ? now : new Date(endDate);
		return sum + Math.floor((end.getTime() - start.getTime()) / msPerDay);
	}, 0);
const workExperienceYears = Math.floor(totalWorkDays / 365.25);
const workExperienceRemainingDays =
	totalWorkDays - Math.floor(workExperienceYears * 365.25);
const workExperienceMonths = Math.floor(workExperienceRemainingDays / 30.4375);
const workExperienceDays =
	workExperienceRemainingDays - Math.floor(workExperienceMonths * 30.4375);
const workExperienceBreakdown = `${workExperienceYears} years, ${workExperienceMonths} months, ${workExperienceDays} days`;

const songEntries = await getCollection('songs', ({ data }) => data.enabled);
const songUrls: string[] = songEntries.map((entry) => entry.data.youtubeEmbedUrl);

const projectEntries = await getCollection('projects');
const projects: Project[] = projectEntries
	.map((entry) => ({ ...entry.data }))
	.sort((a, b) => a.order - b.order);

const heroBlurb = await getEntry('blurbs', 'hero');
const { Content: HeroContent } = await render(heroBlurb!);

const contactBlurb = await getEntry('blurbs', 'contact');
const { Content: ContactContent } = await render(contactBlurb!);

const heroTagEntries = await getCollection('heroTags');
const heroTags = heroTagEntries.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Adam Smith">
	<section class="hero bg-color full-width">
		<h1>Adam Smith</h1>

		<div class="hero-info-tag-list">
			{
				heroTags.map((tag) => (
					<span
						class="hero-info-tag"
						data-tooltip={
							tag.data.label.includes('{years}') ? workExperienceBreakdown : undefined
						}
					>
						<iconify-icon class="iconify-icon" icon={tag.data.icon} />
						<span class="hero-info-tag-text">
							{tag.data.label
								.replace('{years}', String(yearsOfWorkExperience))
								.replace('{location}', latestWorkLocation)}
						</span>
					</span>
				))
			}
		</div>

		<div class="hero-split">
			<div class="hero-content">
				<HeroContent />
			</div>

			<div class="terminal-wrapper">
				<TerminalWidget client:visible />
			</div>
		</div>
	</section>

	<section>
		<h2>Technologies</h2>

		<SkillsWidget skills={skills} client:visible />
	</section>
	<section class="bg-color">
		<h2>My Journey</h2>

		<div class="journey-split">
			<div class="map-wrapper">
				<LocationMap initialCoordinates={timeline[0].coordinates} client:only="svelte" />
			</div>
			<div class="journey-content">
				<Timeline timeline={timeline} client:visible />
			</div>
		</div>
	</section>
	<section>
		<h2>Projects</h2>

		<ProjectsWidget projects={projects} client:visible />
	</section>
	<section>
		<div class="contact-split">
			<div class="left">
				<h2>Contact Me</h2>

				<ContactContent />

				<div class="contact-links">
					<a href={`mailto:${siteResources.emailAddress}`}>
						<iconify-icon class="iconify-icon" icon="mdi:email"></iconify-icon>
						Email
					</a>
					<a href={siteResources.resumeUrl} target="_blank">
						<iconify-icon class="iconify-icon" icon="mdi:file-pdf-box"></iconify-icon>
						Resume
					</a>
					<a href={siteResources.linkedInUrl} target="_blank">
						<iconify-icon class="iconify-icon" icon="mdi:linkedin"></iconify-icon>
						LinkedIn
					</a>
					<a href={siteResources.githubUrl} target="_blank">
						<iconify-icon class="iconify-icon" icon="mdi:github"></iconify-icon>
						GitHub
					</a>
				</div>
			</div>
			<div class="right">
				<MusicPlayer youTubeUrls={songUrls} client:only="svelte" />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.hero h1 {
		font-size: 3.8em;
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1;
		margin-bottom: 0.6rem;
		position: relative;
		display: inline-block;
	}

	.hero h1::after {
		content: '';
		display: block;
		width: 2.5rem;
		height: 3px;
		background-color: var(--color-c);
		margin-top: 0.4rem;
		border-radius: 2px;
	}

	.hero-split {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		grid-template-rows: 1fr;
		column-gap: 2em;
	}

	.terminal-wrapper {
		display: flex;
		flex-direction: column;
		height: auto;
	}

	@media (max-width: 800px) {
		.hero-split {
			grid-template-columns: 1fr;
		}

		.terminal-wrapper {
			display: none;
		}

		.map-wrapper {
			display: none;
		}

		.contact-split {
			flex-direction: column;
		}
	}

	.hero-info-tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-bottom: 0.25rem;
	}

	.hero-info-tag {
		background-color: rgba(212, 134, 10, 0.12);
		color: var(--color-c);
		border: 1px solid rgba(212, 134, 10, 0.3);
		padding: 0.2em 0.55em;
		border-radius: 0.25em;
		font-size: 0.88em;
		font-weight: 500;

		display: flex;
		align-items: center;
		gap: 0.3em;
		vertical-align: middle;
		position: relative;
	}

	.hero-info-tag[data-tooltip] {
		cursor: help;
	}

	.hero-info-tag[data-tooltip]::after {
		content: attr(data-tooltip);
		position: absolute;
		bottom: calc(100% + 0.4em);
		left: 50%;
		transform: translateX(-50%);
		padding: 0.35em 0.6em;
		background-color: rgba(0, 0, 0, 0.9);
		color: #fff;
		font-size: 0.85em;
		font-weight: 500;
		border-radius: 0.25em;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.15s ease;
		z-index: 1;
	}

	.hero-info-tag[data-tooltip]:hover::after,
	.hero-info-tag[data-tooltip]:focus-visible::after {
		opacity: 1;
	}

	.journey-split {
		display: flex;
		gap: 2em;
	}

	.map-wrapper {
		width: 18rem;
		height: 15rem;
		flex-shrink: 0;
	}

	.journey-content {
		flex-grow: 1;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-bottom: 1rem;
	}

	.contact-links > a {
		background-color: var(--color-c);
		color: #0c0b09;
		padding: 0.3em 0.7em;
		border-radius: 0.25em;
		font-weight: 700;
		font-size: 0.9em;

		display: flex;
		align-items: center;
		gap: 0.3em;
		vertical-align: middle;
		text-decoration: none;
		transition: background-color 0.12s ease;
	}

	.contact-links > a:hover {
		background-color: var(--color-h);
		color: #0c0b09;
		text-decoration: none;
	}

	.contact-split {
		display: flex;
		gap: 2em;
		justify-content: space-between;
	}

	.contact-split .right {
		margin-top: 1rem;
		min-width: 350px;
	}
</style>
